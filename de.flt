chat-peak-days = Spitzentage im Chat-Verlauf.


# HISTORY SCANNER

history-scan-prompt = Chat-Verlauf scannen, damit alte Nachrichten in die Chat-Statistiken aufgenommen werden?

history-scan-already-queued = Dein Chat befindet sich bereits in der Warteschlange für den Scan.

history-scan-dont-needed = Ein Scan ist nicht nötig.
    Das Datum des ersten Statistik-Eintrags stimmt mit dem Datum der ersten Nachricht im Chat überein.

history-scan-nor-invite = Gib mir die Berechtigung, Mitglieder einzuladen, oder mache den Chat öffentlich, damit ich den Scanner hinzufügen kann.

history-scan-cant-start = Fehler beim Hinzufügen des Scanners. Stelle sicher, dass ich die Berechtigung habe, neue Mitglieder hinzuzufügen oder den Chat öffentlich zu machen.

history-scan-finished = Erfolgreich gescannt und {$count} Nachrichten zur Statistik hinzugefügt!

history-scan-first-known-msg-older-than-chat = Die erste in der Statistik gespeicherte Nachricht ist älter als die erste verfügbare Nachricht im Chat.
    Wenn du denkst, dass dies ein Fehler ist oder den Chat erneut scannen möchtest, kontaktiere den Bot-Administrator.


# CHAT CLEANING

chat-cleanup-usage = Anwendungsbeispiel:
    /cleanup 7 100
    7 - Anzahl der Tage, 100 - Mindestanzahl von Nachrichten in dieser Zeit.
chat-cleanup-already-running = Die Bereinigung läuft bereits im Chat. Brich sie ab oder versuche es später erneut.
chat-cleanup-nothing-found = 0 Mitglieder für die angegebenen Parameter gefunden.
chat-cleanup-text = {$targetMembersCount} Mitglieder gefunden, die in den letzten {$targetDaysCount} Tagen weniger als {$targetMessagesCount} Nachrichten gesendet haben.

chat-cleanup-nor-set-admin = Der Bot hat nicht die Berechtigung, Admins zu ernennen.
    Erteile die Berechtigung oder nutze den Befehl während der Bereinigung.
chat-cleanup-user-protected-admin = {$name} ist ein Admin, kann bei der Bereinigung nicht entfernt werden und benötigt keinen Schutz.
chat-cleanup-user-marked-rest = {$name} als geschützt markiert.
chat-cleanup-protection-usage = 🛏 <b>!rest</b>: Eine Person vor der Bereinigung schützen (per Name, Benutzername oder Antwort auf eine Nachricht).

    Wenn du den Befehl vor der Bereinigung verwendest, wird der Bot versuchen, die Person zu einem Admin ohne Rechte zu machen und das Label "geschützt" zu setzen.
    Wenn du den Befehl nach !cleanup verwendest, entfernt der Bot die Person aus der Liste.


