# HISTORY SCANNER

history-scan-prompt = चैट इतिहास को स्कैन करें ताकि पुराने संदेश चैट सांख्यिकी में दिखाई दें?

history-scan-already-queued = आपकी चैट पहले से ही स्कैनिंग कतार में है।

history-scan-dont-needed = स्कैन करने की कोई आवश्यकता नहीं है।
    सांख्यिकी की पहली रिकॉर्डिंग की तारीख चैट के पहले संदेश की तारीख से मेल खाती है।

history-scan-nor-invite = मुझे सदस्यों को आमंत्रित करने की अनुमति दें या स्कैनिंग जोड़ने के लिए चैट को सार्वजनिक करें।

history-scan-cant-start = स्कैनर जोड़ने के लिए चैट आईडी प्राप्त नहीं हो सकी। सुनिश्चित करें कि मुझे नए सदस्य जोड़ने की अनुमति है या चैट को सार्वजनिक करें।

history-scan-finished = {$count} संदेश सफलतापूर्वक स्कैन किए गए और सांख्यिकी में जोड़े गए!

history-scan-first-known-msg-older-than-chat = सांख्यिकी में सहेजा गया पहला संदेश चैट में उपलब्ध पहले संदेश से पुराना है।
    यदि आपको लगता है कि यह कोई त्रुटि है या आप चैट को फिर से स्कैन करना चाहते हैं, तो बोट व्यवस्थापक से संपर्क करें।

# CHAT CLEANING

chat-cleanup-usage = उपयोग का उदाहरण:
    !cleanup 7 100
    7 - दिनों की संख्या, 100 - इस दौरान संदेशों की न्यूनतम संख्या।
chat-cleanup-already-running = चैट में पहले से ही सफाई चल रही है। इसे रद्द करें या बाद में प्रयास करें।
chat-cleanup-nothing-found = दिए गए मापदंडों के आधार पर 0 सदस्य मिले।
chat-cleanup-text = {$targetMembersCount} सदस्य मिले, जिन्होंने पिछले {$targetDaysCount} दिनों में {$targetMessagesCount} से कम संदेश लिखे हैं।

chat-cleanup-nor-set-admin = बोट के पास व्यवस्थापक नियुक्त करने की अनुमति नहीं है।
    अनुमति दें या सफाई के दौरान कमांड का उपयोग करें।
chat-cleanup-user-protected-admin = {$name} एडमिन है, उसे सफाई के दौरान नहीं हटाया जा सकता और उसे सुरक्षा की आवश्यकता नहीं है।
chat-cleanup-user-marked-rest = {$name} को 'रेस्ट' के रूप में चिह्नित किया गया है।
chat-cleanup-protection-usage = 🛏 <b>!rest</b>: किसी व्यक्ति को सफाई से बचाएं (नाम, यूजरनेम द्वारा या संदेश के जवाब में)।

    यदि आप सफाई से पहले कमांड कॉल करते हैं, तो बोट उस व्यक्ति को बिना अधिकार के एडमिन बनाने और "rest" हस्ताक्षर सेट करने का प्रयास करेगा।
    यदि आप !cleanup कमांड के बाद कमांड कॉल करते हैं, तो बोट उस व्यक्ति को सूची से हटा देगा।

